# Ollama
# WSL: use `ip route | grep default` to find the gateway IP instead of localhost
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b

# MCP server
MCP_SERVER_URL=http://localhost:8001/mcp

# PostgreSQL (for LangGraph checkpointer)
# WSL: use `ip route | grep default` to find the gateway IP instead of localhost
DATABASE_URL=postgresql://postgres:mypassword@localhost:5432/sheltertech

# Auth0 — leave empty to disable auth (local dev mode)
# AUTH0_DOMAIN=your-tenant.us.auth0.com
# AUTH0_AUDIENCE=navigator-api

# LangSmith observability (optional but recommended for production)
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls__...
# LANGCHAIN_PROJECT=shelter-chat

# Server
PORT=3000
