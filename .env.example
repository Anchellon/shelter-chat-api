# --- LLM provider: Anthropic (Claude) ---
# Set your API key and choose a model per role.
# Recommended: claude-haiku-4-5-20251001 (fast/cheap) or claude-sonnet-4-6 (higher quality)
ANTHROPIC_API_KEY=sk-ant-...

CLASSIFIER_PROVIDER=anthropic
CLASSIFIER_MODEL=claude-haiku-4-5-20251001

INTAKE_PROVIDER=anthropic
INTAKE_MODEL=claude-haiku-4-5-20251001

FORMATTER_PROVIDER=anthropic
FORMATTER_MODEL=claude-haiku-4-5-20251001

# --- LLM provider: Ollama (local, alternative to Anthropic) ---
# WSL: use `ip route | grep default` to find the gateway IP instead of localhost
# OLLAMA_BASE_URL=http://localhost:11434
# CLASSIFIER_PROVIDER=ollama
# CLASSIFIER_MODEL=qwen2.5:14b
# INTAKE_PROVIDER=ollama
# INTAKE_MODEL=qwen2.5:14b
# FORMATTER_PROVIDER=ollama
# FORMATTER_MODEL=qwen2.5:14b

# MCP server
MCP_SERVER_URL=http://localhost:8001/mcp

# PostgreSQL (for LangGraph checkpointer)
# WSL: use `ip route | grep default` to find the gateway IP instead of localhost
DATABASE_URL=postgresql://postgres:mypassword@localhost:5432/sheltertech

# Auth0 — leave empty to disable auth (local dev mode)
# AUTH0_DOMAIN=your-tenant.us.auth0.com
# AUTH0_AUDIENCE=navigator-api

# LangSmith observability (optional but recommended for production)
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls__...
# LANGCHAIN_PROJECT=shelter-chat

# Server
PORT=3000
